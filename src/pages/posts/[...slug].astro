---
import { BlocksRenderer } from "@strapi/blocks-react-renderer";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Page from "../../components/Page.astro";
import TopicContainer from "../../components/TopicContainer.astro";
import References from "../../components/References.astro";
import { SITE_DESCRIPTION } from "../../consts";
import type { Post, Topic } from "../../interfaces/strapi";
import BlogPost from "../../layouts/BlogPost.astro";
import { getPosts } from "../../lib/strapi";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.documentId },
    props: post,
  }));
}

type Props = Post;

const post = Astro.props;

---

<Page title={post.title} description={post.title}>
  <h1 class="text-4xl font-bold">
    {post.title}
  </h1>
  <FormattedDate date={new Date(post.publication_date)} />
  <div class="flex my-4">
    {post.topics?.map((topic: Topic) => <TopicContainer topic={topic} />)}
  </div>
  <BlocksRenderer content={post.content} />
  <References references={post.references || []} />
</Page>
