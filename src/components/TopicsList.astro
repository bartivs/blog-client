---
import type { Topic } from "../interfaces/strapi";
import { getTopics } from "../lib/strapi";
import TopicContainer from "./TopicContainer.astro";


const topics = await getTopics(); 
---

<div class="flex items-center lg:w-40">
  { topics.length > 1 && topics?.map((topic) => <TopicContainer topic={topic} />)}
</div>
