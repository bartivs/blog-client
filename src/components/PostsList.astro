---
import type { Post } from "../interfaces/strapi";
import FormattedDate from "./FormattedDate.astro";
import TopicContainer from "./TopicContainer.astro";
import TopicsList from "./TopicsList.astro";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
console.log('posts', posts);
---

<div class="flex flex-col lg:flex-row">
  <div class="mb-4 lg:mb-0">
    <TopicsList />
  </div>
  <div class="flex flex-col flex-1">
    {
      posts?.map((post: Post) => (
            <div class="border-b-2 py-2 border-white flex justify-between">
              <div>
                <a href={`/posts/${post.documentId}/`}>{post.title}</a>
                <div class="mt-1">
                  {post.topics?.map((topic) => (
                    <TopicContainer topic={topic} />
                  ))}
                </div>
              </div>
              <div>
                <FormattedDate date={new Date(post.publication_date)} />
              </div>
            </div>
      ))
    }
  </div>
</div>
