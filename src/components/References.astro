---
import type { Reference } from '../interfaces/strapi';

interface Props {
    references: Reference[];
}

const { references } = Astro.props;
---

{references && references.length > 0 && (
    <div class="mt-8 pt-8 border-t border-slate-600 text-white">
        <h2 class="text-xl font-bold mb-4">References</h2>
        <ul class="list-disc list-inside space-y-2">
            {references.map((ref: Reference) => (
                <li>
                    <a 
                        href={ref.url} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="text-blue-400 hover:text-blue-300 underline"
                    >
                        {ref.title}
                    </a>
                </li>
            ))}
        </ul>
    </div>
)}
